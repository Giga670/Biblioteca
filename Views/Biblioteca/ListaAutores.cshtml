@model List<Biblioteca.Models.Autor>
<link rel="stylesheet" href="~/css/style.css">

<h2>Autores</h2>
<p class="mb-3">
    <a class="btn btn-primary" asp-action="CriarAutor">+ Novo autor</a>
</p>

@if (Model.Count == 0)
{
    <p>Ainda não há autores na base de dados.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead>
            <tr>
                <th>Id</th>
                <th>Nome</th>
                <th>Nacionalidade</th>
                <th>Período</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.Id</td>
                    <td>@a.Nome</td>
                    <td>@a.Nacionalidade</td>
                    <td>@a.Periodo</td>
                    <td>
                        <a asp-action="AutorDetalhe" asp-route-id="@a.Id">Detalhe</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
